<Window x:Class="WpfImageToText.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="#70000000"
        Topmost="True" WindowState="Maximized" KeyDown="OverlayWindow_KeyDown">
    <Grid>
        <!-- Instructions qui apparaissent au-dessus -->
        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,50,0,0"
                  Foreground="White" FontSize="16" TextAlignment="Center"
                  Background="#AA000000" Padding="10">
            <TextBlock.Effect>
                <DropShadowEffect ShadowDepth="2" Color="Black" Opacity="0.7" BlurRadius="4"/>
            </TextBlock.Effect>
            <Run Text="Sélectionnez une zone à capturer"/>
            <LineBreak/>
            <Run Text="Appuyez sur Échap pour annuler" FontSize="14"/>
            <LineBreak/>
            <Run Text="Raccourci : Ctrl+Shift+C" FontSize="12" FontStyle="Italic"/>
        </TextBlock>
        
        <!-- Canvas pour la sélection -->
        <Canvas x:Name="SelectionCanvas"/>
        
        <!-- Affichage des dimensions de la sélection -->
        <Border x:Name="DimensionsDisplay" Background="#CC000000" CornerRadius="3"
                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,10"
                Padding="8,4" Visibility="Collapsed">
            <TextBlock x:Name="DimensionsText" Foreground="White" FontSize="12"/>
        </Border>
    </Grid>
</Window>