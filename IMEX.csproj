  </ItemGroup>

  <ItemGroup>
    <None Remove="C:\Users\eudef\.nuget\packages\tesseract.net.sdk\4.6.411\build\..\content\tessdata\equ.traineddata" />
  </ItemGroup>

  <ItemGroup>
